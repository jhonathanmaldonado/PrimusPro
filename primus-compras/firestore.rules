rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(wid) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/workspaces/$(wid)/usuarios/$(request.auth.uid));
    }

    function userRole(wid) {
      return get(/databases/$(database)/documents/workspaces/$(wid)/usuarios/$(request.auth.uid)).data.role;
    }

    function isOwner(wid) {
      return isMember(wid) && userRole(wid) == 'dono';
    }

    function workspaceSemDono(wid) {
      return !exists(/databases/$(database)/documents/workspaces/$(wid)) ||
        (
          exists(/databases/$(database)/documents/workspaces/$(wid)) &&
          !('owner' in get(/databases/$(database)/documents/workspaces/$(wid)).data)
        ) ||
        (
          exists(/databases/$(database)/documents/workspaces/$(wid)) &&
          get(/databases/$(database)/documents/workspaces/$(wid)).data.owner == null
        );
    }

    match /workspaces/{wid} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isOwner(wid);

      match /auth_lookup/{uid} {
        allow read: if true;
        allow create: if isSignedIn() && (workspaceSemDono(wid) || isOwner(wid) || request.auth.uid == uid);
        allow update: if isSignedIn() && (
          isOwner(wid) ||
          request.auth.uid == uid ||
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['tentativasFalhas', 'bloqueadoAte', 'ultimoLoginEm'])
          )
        );
        allow delete: if isOwner(wid);
      }

      match /usuarios/{uid} {
        allow read: if isMember(wid) || (isSignedIn() && request.auth.uid == uid);
        allow create: if isSignedIn() && (workspaceSemDono(wid) || isOwner(wid) || request.auth.uid == uid);
        allow update: if isSignedIn() && (isOwner(wid) || request.auth.uid == uid);
        allow delete: if isOwner(wid);
      }

      match /categorias/{catId} {
        allow read, write: if isMember(wid);
      }

      match /itens/{itemId} {
        allow read, write: if isMember(wid);
      }

      match /lista_em_criacao/{itemId} {
        allow read, write: if isMember(wid);
      }

      match /lista_atual/{itemId} {
        allow read, write: if isMember(wid);
      }

      match /historico/{histId} {
        allow read: if isMember(wid);
        allow create: if isMember(wid);
        allow update, delete: if isOwner(wid);
      }

      match /fornecedores/{fornId} {
        allow read, write: if isMember(wid);
      }

      match /insumos/{insumoId} {
        allow read, write: if isMember(wid);
      }

      match /fichas/{fichaId} {
        allow read, write: if isMember(wid);
      }

      match /vendas_dias/{diaId} {
        allow read, write: if isMember(wid);
      }

      match /vendas/{vendaId} {
        allow read, write: if isMember(wid);
      }
    }
  }
}